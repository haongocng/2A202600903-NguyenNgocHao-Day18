# cp .env.example .env
# Required for M4 (RAGAS eval) and M5 (Enrichment LLM calls)
OPENAI_API_KEY=sk-...

MINIMAX_API_KEY=sk-
MINIMAX_BASE_URL=https://api.tokenrouter.com/v1
MINIMAX_MODEL=MiniMax-M3

# Embedding api key
COHERE_API_KEY=api_key

# Jina AI (Task 7 - Reranking, optional)
JINA_API_KEY=jina_api_key

# PageIndex (Task 8 - Vectorless RAG)
PAGEINDEX_API_KEY=page_index_api_key

# Weaviate Cloud (Task 4, optional - can use local Docker instead)
WEAVIATE_URL=url
WEAVIATE_API_KEY=api_key
